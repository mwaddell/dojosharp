<!-- Attribute Types -->

<xsd:simpleType name="constructor">
    <xsd:restriction base="xsd:string">
        <xsd:enumeration value="" />
        <xsd:enumeration value="constructor" />
        <xsd:enumeration value="preamble" />
        <xsd:enumeration value="postscript" />
    </xsd:restriction>
</xsd:simpleType>

<xsd:simpleType name="usage">
    <xsd:restriction base="xsd:string">
        <xsd:enumeration value="required" />
        <xsd:enumeration value="optional" />
        <xsd:enumeration value="one-or-more" />
    </xsd:restriction>
</xsd:simpleType>

<xsd:simpleType name="scope">
    <xsd:restriction base="xsd:string">
        <xsd:enumeration value="normal" />
        <xsd:enumeration value="prototype" />
        <xsd:enumeration value="instance" />
        <xsd:enumeration value="instance-prototype" />
    </xsd:restriction>
</xsd:simpleType>

<!-- Element Types -->

<xsd:element name="javascript">
    <xsd:annotation>
        <xsd:documentation xml:lang="en">The root node in the file.
        </xsd:documentation>
    </xsd:annotation>
    <xsd:complexType>
        <xsd:sequence>
            <xsd:element ref="object" minOccurs="1" maxOccurs="unbounded" />
        </xsd:sequence>
    </xsd:complexType>
</xsd:element>

<xsd:element name="object">
    <xsd:complexType>
        <xsd:choice minOccurs="0" maxOccurs="unbounded">
            <xsd:element ref="resources" />
            <xsd:element ref="provides" />
            <xsd:element ref="parameters" />
            <xsd:element name="summary" type="xsd:string" />
            <xsd:element name="description" type="xsd:string" />
            <xsd:element ref="examples" />
            <xsd:element ref="mixins" />
            <xsd:element ref="properties" />
            <xsd:element ref="methods" />
            <xsd:element ref="return-types" />
        </xsd:choice>

        <xsd:attribute name="location" type="xsd:string" default="" />
        <xsd:attribute name="type" type="xsd:string" default="" />
        <xsd:attribute name="tags" type="xsd:string" default="" />
        <xsd:attribute name="classlike" type="xsd:boolean" default="false" />
        <xsd:attribute name="superclass" type="xsd:string" use="optional" />
        <xsd:attribute name="private" type="xsd:boolean" default="false" />
        <xsd:attribute name="privateparent" type="xsd:boolean" default="false" />
    </xsd:complexType>
</xsd:element>

<xsd:element name="resources">
    <xsd:complexType>
        <xsd:sequence>
            <xsd:element name="resource" type="xsd:string" minOccurs="1" maxOccurs="unbounded" />
        </xsd:sequence>
    </xsd:complexType>
</xsd:element>

<xsd:element name="provides">
    <xsd:complexType>
        <xsd:sequence>
            <xsd:element name="provide" type="xsd:string" minOccurs="1" maxOccurs="unbounded" />
        </xsd:sequence>
    </xsd:complexType>
</xsd:element>

<xsd:element name="methods">
    <xsd:complexType>
        <xsd:sequence>
            <xsd:element ref="method" minOccurs="1" maxOccurs="unbounded" />
            <xsd:element ref="properties" minOccurs="0" maxOccurs="1" />
        </xsd:sequence>
    </xsd:complexType>
</xsd:element>

<xsd:element name="method">
    <xsd:complexType>
        <xsd:all>
            <xsd:element ref="resources" minOccurs="0" maxOccurs="1" />
            <xsd:element ref="provides" minOccurs="0" maxOccurs="1" />
            <xsd:element name="summary" type="xsd:string" minOccurs="0" maxOccurs="1" />
            <xsd:element name="description" type="xsd:string" minOccurs="0" maxOccurs="1" />
            <xsd:element ref="examples" minOccurs="0" maxOccurs="1" />
            <xsd:element name="return-description" type="xsd:string" minOccurs="0" maxOccurs="1" />
            <xsd:element ref="parameters" minOccurs="0" maxOccurs="1" />
            <xsd:element ref="return-type" minOccurs="0" maxOccurs="1" />
            <xsd:element ref="return-types" minOccurs="0" maxOccurs="1" />
        </xsd:all>
        <xsd:attribute name="name" type="xsd:string" default="" />
        <xsd:attribute name="scope" type="scope" use="optional" />
        <xsd:attribute name="type" type="xsd:string" default="" />
        <xsd:attribute name="private" type="xsd:boolean" default="false" />
        <xsd:attribute name="privateparent" type="xsd:boolean" default="false" />
        <xsd:attribute name="tags" type="xsd:string" default="" />
        <xsd:attribute name="constructor" type="constructor" default="" />
    </xsd:complexType>
</xsd:element>

<xsd:element name="examples">
    <xsd:complexType>
        <xsd:sequence>
            <xsd:element name="example" type="xsd:string" minOccurs="1" maxOccurs="unbounded" />
        </xsd:sequence>
    </xsd:complexType>
</xsd:element>

<xsd:element name="parameters">
    <xsd:complexType>
        <xsd:sequence>
            <xsd:element ref="parameter" minOccurs="0" maxOccurs="unbounded" />
        </xsd:sequence>
    </xsd:complexType>
</xsd:element>

<xsd:element name="return-types">
    <xsd:complexType>
        <xsd:sequence>
            <xsd:element ref="return-type" minOccurs="0" maxOccurs="unbounded" />
        </xsd:sequence>
    </xsd:complexType>
</xsd:element>

<xsd:element name="properties">
    <xsd:complexType>
        <xsd:sequence>
            <xsd:element ref="property" minOccurs="1" maxOccurs="unbounded" />
        </xsd:sequence>
    </xsd:complexType>
</xsd:element>

<xsd:element name="property">
    <xsd:complexType mixed="true">
        <xsd:all>
            <xsd:element ref="resources" minOccurs="0" maxOccurs="1" />
            <xsd:element ref="provides" minOccurs="0" maxOccurs="1" />
            <xsd:element name="summary" type="xsd:string" minOccurs="0" maxOccurs="1" />
            <xsd:element name="description" type="xsd:string" minOccurs="0" maxOccurs="1" />
        </xsd:all>
        <xsd:attribute name="name" type="xsd:string" use="required" />
        <xsd:attribute name="scope" type="scope" use="required" />
        <xsd:attribute name="type" type="xsd:string" use="required" />
        <xsd:attribute name="private" type="xsd:boolean" default="false" />
        <xsd:attribute name="privateparent" type="xsd:boolean" default="false" />
        <xsd:attribute name="tags" type="xsd:string" default="" />
    </xsd:complexType>
</xsd:element>

<xsd:element name="parameter">
    <xsd:complexType mixed="true">
        <xsd:sequence>
            <xsd:element name="summary" type="xsd:string" minOccurs="0" maxOccurs="1" />
        </xsd:sequence>
        <xsd:attribute name="name" type="xsd:string" use="required" />
        <xsd:attribute name="type" type="xsd:string" use="required" />
        <xsd:attribute name="usage" type="usage" use="required" />
        <xsd:attribute name="privateparent" type="xsd:boolean" default="false" />
        <xsd:attribute name="tags" type="xsd:string" default="" />
    </xsd:complexType>
</xsd:element>

<xsd:element name="return-type">
    <xsd:complexType>
        <xsd:attribute name="type" type="xsd:string" use="required" />
    </xsd:complexType>
</xsd:element>

<xsd:element name="mixins">
    <xsd:complexType>
        <xsd:sequence>
            <xsd:element ref="mixin" minOccurs="1" maxOccurs="unbounded" />
        </xsd:sequence>
        <xsd:attribute name="scope" type="scope" use="optional" />
    </xsd:complexType>
</xsd:element>

<xsd:element name="mixin">
    <xsd:complexType>
        <xsd:attribute name="scope" type="scope" use="required" />
        <xsd:attribute name="location" type="xsd:string" default="" />
    </xsd:complexType>
</xsd:element>

</xsd:schema>
